<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="省份"
            android:textColor="@color/gray"
            android:textSize="13sp" />

        <Spinner
            android:id="@+id/spProvince"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="城市"
            android:textColor="@color/gray"
            android:textSize="13sp" />

        <Spinner
            android:id="@+id/spCity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="区 / 气象站区域（可选）"
            android:textColor="@color/gray"
            android:textSize="13sp" />

        <Spinner
            android:id="@+id/spArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="仅提供中国气象局可用的区域站点，请自行选择距离最近的区域；没有合适选项时保持“不选择”。"
            android:textColor="@color/section_label"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="雷达地区"
            android:textColor="@color/gray"
            android:textSize="13sp" />

        <Spinner
            android:id="@+id/spDialogRegion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="和风天气 API Key（短临降水，可留空）"
            android:textColor="@color/gray"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etQKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="粘贴你的 API KEY"
            android:inputType="text"
            android:maxLines="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="和风天气 API Host"
            android:textColor="@color/gray"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etQHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="如 abcd1234.qweatherapi.com"
            android:inputType="textUri"
            android:maxLines="1" />
    </LinearLayout>
</ScrollView>
