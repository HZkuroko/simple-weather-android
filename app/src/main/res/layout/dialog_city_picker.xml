<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="省份"
            android:textColor="@color/gray"
            android:textSize="13sp" />

        <com.example.nmcweather.LimitedSpinner
            android:id="@+id/spProvince"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="城市"
            android:textColor="@color/gray"
            android:textSize="13sp" />

        <com.example.nmcweather.LimitedSpinner
            android:id="@+id/spCity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="降雨预测（可选）"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="分钟降雨预测 API Key（可留空）"
            android:textColor="@color/gray"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etQKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="粘贴你的 API KEY"
            android:inputType="text"
            android:maxLines="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="分钟降雨预测 API Host"
            android:textColor="@color/gray"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etQHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="如 abcd1234.qweatherapi.com"
            android:inputType="textUri"
            android:maxLines="1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="仅用于降雨预测；和风凭据只需启用 GeoAPI 和“分钟降水”。留空时主天气仍正常使用中央气象局。"
            android:textColor="@color/section_label"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="中央气象局行政区 / 气象站（可选）"
                android:textColor="@color/gray"
                android:textSize="13sp" />

            <com.example.nmcweather.LimitedSpinner
                android:id="@+id/spNmcArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="仅提供中国气象局可用的区域站点，请自行选择距离最近的区域；没有合适选项时保持“不选择”。"
                android:textColor="@color/section_label"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="雷达类型"
            android:textColor="@color/gray"
            android:textSize="13sp" />

        <com.example.nmcweather.LimitedSpinner
            android:id="@+id/spRadarType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:id="@+id/layoutRadarRegion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="具体区域"
                android:textColor="@color/gray"
                android:textSize="13sp" />

            <com.example.nmcweather.LimitedSpinner
                android:id="@+id/spRadarRegion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutRadarStation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="单站所在省份 / 直辖市"
                android:textColor="@color/gray"
                android:textSize="13sp" />

            <com.example.nmcweather.LimitedSpinner
                android:id="@+id/spRadarProvince"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="具体雷达站"
                android:textColor="@color/gray"
                android:textSize="13sp" />

            <com.example.nmcweather.LimitedSpinner
                android:id="@+id/spRadarStation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="站点列表按中央气象局当前官方目录整理；下拉框最多显示 5 行，可继续滚动。"
                android:textColor="@color/section_label"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
