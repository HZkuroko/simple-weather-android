<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="天气数据源"
            android:textColor="@color/gray"
            android:textSize="13sp" />

        <RadioGroup
            android:id="@+id/rgWeatherSource"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbNmc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="中央气象局" />

            <RadioButton
                android:id="@+id/rbQWeather"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="和风天气" />
        </RadioGroup>

        <TextView
            android:id="@+id/tvSourceHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="和风模式只有在 API Key 和 Host 均已填写时生效，否则自动使用中央气象局。"
            android:textColor="@color/section_label"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="省份"
            android:textColor="@color/gray"
            android:textSize="13sp" />

        <com.example.nmcweather.LimitedSpinner
            android:id="@+id/spProvince"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="城市"
            android:textColor="@color/gray"
            android:textSize="13sp" />

        <com.example.nmcweather.LimitedSpinner
            android:id="@+id/spCity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="和风天气 API Key（可留空）"
            android:textColor="@color/gray"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etQKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="粘贴你的 API KEY"
            android:inputType="text"
            android:maxLines="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="和风天气 API Host"
            android:textColor="@color/gray"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etQHost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="如 abcd1234.qweatherapi.com"
            android:inputType="textUri"
            android:maxLines="1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="使用和风区县天气需在凭据权限中启用：GeoAPI、天气预报；分钟降水功能还需启用“分钟降水”。"
            android:textColor="@color/section_label"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/layoutNmcArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="中央气象局行政区 / 气象站（可选）"
                android:textColor="@color/gray"
                android:textSize="13sp" />

            <com.example.nmcweather.LimitedSpinner
                android:id="@+id/spNmcArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="仅提供中国气象局可用的区域站点，请自行选择距离最近的区域；没有合适选项时保持“不选择”。"
                android:textColor="@color/section_label"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutQArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="和风行政区（独立列表，可选）"
                android:textColor="@color/gray"
                android:textSize="13sp" />

            <com.example.nmcweather.LimitedSpinner
                android:id="@+id/spQArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/btnLoadQAreas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="加载 / 刷新和风行政区"
                android:textAllCaps="false" />

            <TextView
                android:id="@+id/tvQAreaHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="先填写 Key 和 Host，再加载当前城市的和风行政区；保持“不选择”时使用城市级天气。"
                android:textColor="@color/section_label"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="雷达类型"
            android:textColor="@color/gray"
            android:textSize="13sp" />

        <com.example.nmcweather.LimitedSpinner
            android:id="@+id/spRadarType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:id="@+id/layoutRadarRegion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="具体区域"
                android:textColor="@color/gray"
                android:textSize="13sp" />

            <com.example.nmcweather.LimitedSpinner
                android:id="@+id/spRadarRegion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutRadarStation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="单站所在省份 / 直辖市"
                android:textColor="@color/gray"
                android:textSize="13sp" />

            <com.example.nmcweather.LimitedSpinner
                android:id="@+id/spRadarProvince"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="具体雷达站"
                android:textColor="@color/gray"
                android:textSize="13sp" />

            <com.example.nmcweather.LimitedSpinner
                android:id="@+id/spRadarStation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="站点列表按中央气象局当前官方目录整理；下拉框最多显示 5 行，可继续滚动。"
                android:textColor="@color/section_label"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
